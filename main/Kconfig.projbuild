menu "App Configuration"

config APP_WIFI_SSID
    string "Wi-Fi SSID"
    default "YOUR_WIFI_SSID"

config APP_WIFI_PASS
    string "Wi-Fi Password"
    default "YOUR_WIFI_PASSWORD"

config APP_MQTT_URI
    string "MQTT broker URI (e.g., mqtt://192.168.1.10)"
    default "mqtt://192.168.1.10"

config APP_MQTT_BASE_TOPIC
    string "Base MQTT topic for this node"
    default "ultralights/node"

config APP_LED_GPIO
    int "WS2812B data GPIO"
    range 0 21
    default 0

config APP_LED_COUNT
    int "Number of LEDs"
    range 1 3000
    default 300

config APP_DEFAULT_BRIGHTNESS_PCT
    int "Default brightness (%)"
    range 0 100
    default 100

config APP_OTA_DEFAULT_URL
    string "Default OTA URL (used by scheduled OTA)"
    default "https://your.server/firmware.bin"

config APP_OTA_SKIP_CERT_VALIDATION
    bool "Skip TLS certificate validation (development only)"
    default n

menu "Presence Sensors"

config APP_ENABLE_PIR
    bool "Enable PIR motion sensor"
    default n

config APP_PIR_GPIO
    int "PIR sensor GPIO"
    depends on APP_ENABLE_PIR
    range 0 40
    default 33

config APP_ENABLE_ULTRASONIC
    bool "Enable HC-SR04 ultrasonic sensor"
    default n

config APP_ULTRASONIC_TRIG_GPIO
    int "Ultrasonic trigger GPIO"
    depends on APP_ENABLE_ULTRASONIC
    range 0 40
    default 26

config APP_ULTRASONIC_ECHO_GPIO
    int "Ultrasonic echo GPIO"
    depends on APP_ENABLE_ULTRASONIC
    range 0 40
    default 27

config APP_ULTRASONIC_NEAR_CM
    int "Distance (cm) considered 'near'"
    depends on APP_ENABLE_ULTRASONIC
    range 1 500
    default 50

config APP_PRESENCE_LOW_BRIGHTNESS_PCT
    int "Brightness when presence detected (%)"
    range 0 100
    default 20

config APP_PRESENCE_NEAR_BRIGHTNESS_PCT
    int "Brightness when near (%)"
    range 0 100
    default 100

config APP_NEAR_LIGHT1_GPIO
    int "GPIO for extra light 1 (-1 to disable)"
    range -1 40
    default -1

config APP_NEAR_LIGHT2_GPIO
    int "GPIO for extra light 2 (-1 to disable)"
    range -1 40
    default -1

endmenu

endmenu

menu "UltraLights OTA"

config APP_DEVICE_ID
    string "Device ID"
    default "device123"

config APP_PUBLIC_BASE
    string "Public base URL"
    default "https://lights.example.com"

config APP_MANIFEST_PATH
    string "Manifest path"
    default "/api/firmware/v1/manifest"

config APP_API_BEARER
    string "API Bearer token (optional)"
    default ""

config APP_MANIFEST_HMAC_HEX
    string "Manifest HMAC secret (hex)"
    default ""  # put 64 hex chars (32 bytes) when you enable signed manifests

endmenu
